rules_version = '2'
service firebase.storage {
  match /b/{bucket}/o {
    // Public gallery images
    match /gallery/{allPaths=**} {
      allow read: if true
      allow write: if request.auth != null
    }

    // Walk check-in/check-out photos
    match /walks/{allPaths=**} {
      allow read: if request.auth != null
      allow write: if request.auth != null
    }

    // Client pet photos
    match /pets/{allPaths=**} {
      allow read: if request.auth != null
      allow write: if request.auth != null
    }
  }
}
